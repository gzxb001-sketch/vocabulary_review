generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SourceType {
  exam
  reading
  lecture
  manual
  other
}

enum WordStatus {
  active
  archived
}

enum ReviewResult {
  known
  vague
  forgot
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  words         Word[]
  sources       WordSource[]
  meanings      Meaning[]
  reviews       Review[]
  reviewSchedule ReviewSchedule[]
}

model Word {
  id              String          @id @default(cuid())
  userId          String
  lemma           String
  displayText     String
  meaningZh       String?
  phonetic        String?
  partOfSpeech    String?
  exampleSentence String?
  note            String?
  status          WordStatus      @default(active)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources         WordSource[]
  reviews         Review[]
  schedule        ReviewSchedule[]
  meanings        Meaning[]

  @@index([lemma])
  @@index([displayText])
  @@index([userId])
}

model Meaning {
  id                  String   @id @default(cuid())
  wordId              String
  userId              String
  partOfSpeech        String
  meaningZh           String
  exampleSentence     String?
  exampleTranslation  String?
  isObscure           Boolean  @default(false)
  isHighFreq          Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())

  word                Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wordId])
  @@index([userId])
}

model WordSource {
  id            String     @id @default(cuid())
  wordId        String
  userId        String
  sourceType    SourceType
  sourceNote    String?
  sourceContext String?
  imageId       String?
  createdAt     DateTime   @default(now())

  word          Word       @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  image         Image?     @relation(fields: [imageId], references: [id], onDelete: SetNull)

  @@index([wordId])
  @@index([sourceType])
  @@index([imageId])
  @@index([userId])
}

model Image {
  id         String       @id @default(cuid())
  filePath   String
  ocrRawText String?
  createdAt  DateTime     @default(now())

  sources    WordSource[]
}

model ReviewSchedule {
  id            String        @id @default(cuid())
  wordId        String
  userId        String
  nextReviewAt  DateTime
  intervalDays  Int           @default(0)
  easeScore     Float         @default(2.5)
  reviewCount   Int           @default(0)
  lastResult    ReviewResult?
  updatedAt     DateTime      @updatedAt

  word          Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([wordId, userId])
  @@index([nextReviewAt])
  @@index([userId])
  @@index([wordId])
}

model Review {
  id             String       @id @default(cuid())
  wordId         String
  userId         String
  reviewResult   ReviewResult
  reviewedAt     DateTime     @default(now())
  intervalBefore Int?
  intervalAfter  Int?

  word           Word         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wordId, reviewedAt])
  @@index([userId])
}
